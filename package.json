{
  "name": "ctscout-mcp-server",
  "version": "0.2.5",
  "description": "MCP server for ctscout.dev — domain attribution via Certificate Transparency + multi-signal Pro enrichment",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ctscout-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LIMITATIONS.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "tsc -p tsconfig.test.json",
    "prepublishOnly": "npm run clean && npm run build",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ctscout",
    "domain-discovery",
    "certificate-transparency",
    "claude",
    "anthropic"
  ],
  "author": "minghsuy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minghsuy/ctscout-mcp.git"
  },
  "homepage": "https://ctscout.dev",
  "bugs": {
    "url": "https://github.com/minghsuy/ctscout-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
